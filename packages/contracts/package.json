{
  "name": "@labelhub/contracts",
  "version": "1.1.0",
  "private": true,
  "description": "LabelHub 共享契约类型包",
  "type": "module",
  "types": "./src/index.ts",
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsc -p tsconfig.test.json && node -e \"require('node:fs').writeFileSync('./.contract-test-dist/package.json', '{\\\"type\\\":\\\"commonjs\\\"}\\n')\" && node --test ./.contract-test-dist/src/__tests__/*.test.js",
    "clean:test": "rm -rf ./.contract-test-dist"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts"
    }
  },
  "devDependencies": {
    "typescript": "^5.0.0"
  }
}
