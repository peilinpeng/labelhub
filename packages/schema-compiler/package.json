{
  "name": "@labelhub/schema-compiler",
  "version": "0.1.0",
  "private": true,
  "description": "LabelHub Schema 编译与静态分析包",
  "type": "module",
  "types": "./src/index.ts",
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
