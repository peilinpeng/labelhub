{
  "name": "@labelhub/schema-renderer",
  "version": "0.1.0",
  "private": true,
  "description": "LabelHub 动态 Schema React 渲染层",
  "type": "module",
  "types": "./src/index.ts",
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
