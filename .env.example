# LabelHub 环境变量模板
# 用法：cp .env.example .env 然后按需填写真实值。docker compose 会自动读取根目录 .env。
# 切勿把真实密钥提交进仓库（.env 已在 .gitignore 中忽略）。

# ── 数据库 / 缓存 ──────────────────────────────────────────────
# 本机 compose 默认即可；云部署改为云数据库 / 云 Redis 地址。
DATABASE_URL=mysql+pymysql://labelhub:labelhub@mysql:3306/labelhub
REDIS_URL=redis://redis:6379

# compose 内置 MySQL 的初始化账号（仅用 compose 自带 mysql 时需要）
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=labelhub
MYSQL_USER=labelhub
MYSQL_PASSWORD=labelhub

# ── JWT 鉴权 ──────────────────────────────────────────────────
# 生产环境务必改成高强度随机值，例如：openssl rand -hex 32
JWT_SECRET=change_me_to_a_long_random_secret

# ── 豆包 / OpenAI 兼容 LLM 接口 ───────────────────────────────
# 举办方提供的模型接入点与 key 见课题 PDF；此处填你自己的值，勿提交真实 key。
DOUBAO_API_KEY=your_doubao_api_key_here
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_MODEL=ep-xxxxxxxxxxxxxxxxx

# ── 文件存储 ──────────────────────────────────────────────────
FILE_STORAGE_DRIVER=local
LOCAL_STORAGE_DIR=/workspace/.storage/files

# ── 前端 / 端口（compose 级）──────────────────────────────────
# 真实后端模式（演示用）：MSW 关闭，Vite /api 代理到 api 容器。
VITE_ENABLE_MSW=false
VITE_PROXY_TARGET=http://api:3000
# 宿主暴露端口（按需改，避免与本机其他服务冲突）
API_PORT=3000
WEB_PORT=5173
